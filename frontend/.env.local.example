# =====================================================
# Frontend (Next.js) 로컬 개발용 환경변수 샘플
# 사용법: cp .env.local.example .env.local
# .env.local 은 .gitignore 로 추적 제외
# =====================================================

# --- 브라우저 노출 (NEXT_PUBLIC_*) ---
# 모든 API 호출은 BFF (/api/proxy/*) 를 경유한다.
NEXT_PUBLIC_API_BASE_URL=/api/proxy

# --- 서버 사이드 전용 (BFF 프록시 라우트만 사용) ---
# EC2 백엔드 주소. 로컬 dev 시에는 http://localhost:8080
# 운영(Vercel)에서는 EC2 퍼블릭 IP 또는 사설망 주소를 지정.
EC2_API_URL=http://localhost:8080
