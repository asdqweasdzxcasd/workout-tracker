# =====================================================
# workout-tracker 운영 환경변수 예시
# 사용법:
#   1) cp deploy/.env.example deploy/.env
#   2) deploy/.env 파일에 실제 값 입력
#   3) deploy/.env 는 .gitignore 처리되어 commit 되지 않음
#
# 보안 주의:
# - 이 파일에는 절대 실제 비밀번호/키를 적지 않는다
# - .env 파일은 ssh/scp 또는 GitHub Actions Secrets 로만 전송
# =====================================================

# -----------------------------------------------------
# Spring Boot Profile
# -----------------------------------------------------
SPRING_PROFILES_ACTIVE=prod

# -----------------------------------------------------
# Database (AWS RDS PostgreSQL 16)
# - RDS 엔드포인트 / DB 이름 / 마스터 사용자 / 마스터 비밀번호
# - SG 인바운드 5432 가 EC2 SG 에서 허용되어 있어야 함
# -----------------------------------------------------
DB_URL=jdbc:postgresql://<RDS-INSTANCE-ID>.<RDS-RESOURCE-ID>.<REGION>.rds.amazonaws.com:5432/workout_tracker
DB_USERNAME=workout
DB_PASSWORD=여기에RDS마스터암호입력

# -----------------------------------------------------
# JWT
# - HS256 알고리즘이라 64자 이상 권장 (최소 32자)
# - 로컬 dev 시크릿을 절대 재사용하지 말 것
# - 생성 예: openssl rand -base64 64
# -----------------------------------------------------
JWT_SECRET=반드시64자이상의랜덤문자열로교체할것dummy0000000000000000000000000000
JWT_EXPIRES_IN=3600

# -----------------------------------------------------
# AWS
# - region / S3 bucket
# - Phase 6.2 (현재): IAM 사용자 AccessKey/SecretKey 환경변수 주입
# - Phase 6.3 (다음): EC2 IAM Role 부착 -> AccessKey 환경변수 삭제 권장
# -----------------------------------------------------
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=<S3-BUCKET-NAME>
# Phase 6.3 이후로는 EC2 IAM Role 사용 → 아래 두 줄 불필요
# AWS_ACCESS_KEY_ID=AKIA로시작하는AccessKey
# AWS_SECRET_ACCESS_KEY=여기에SecretKey입력

# (선택) presigned URL 만료시간 - application-prod.yml 기본값 사용 가능
# AWS_S3_PRESIGN_UPLOAD_EXPIRES_SEC=300
# AWS_S3_PRESIGN_DOWNLOAD_EXPIRES_SEC=900

# -----------------------------------------------------
# CORS
# - 운영은 BFF 경유라 사실상 미발동, 안전망용
# - 로컬 -> 운영 직접호출 디버깅, Vercel preview 등 대비
# -----------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://*.vercel.app
