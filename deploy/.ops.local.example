# =====================================================
# AWS 스택 켜기/끄기 오케스트레이션 시크릿
# 사용법: 이 파일을 복사해서 deploy/.ops.local 로 저장하고 값 채우기
#   cp deploy/.ops.local.example deploy/.ops.local
# deploy/.ops.local 은 .gitignore 로 추적 제외됨. 절대 commit 금지.
# aws-stack.ps1 이 이 파일을 읽어 Cloudflare DNS 를 갱신한다.
# =====================================================

# Cloudflare API 토큰 (Zone > DNS > Edit, eeiu.net 존 한정)
CLOUDFLARE_API_TOKEN=

# 백엔드 고정 도메인 (프론트 EC2_API_URL 이 항상 이 주소를 가리킴)
CLOUDFLARE_ZONE=eeiu.net
BACKEND_FQDN=workout-api.eeiu.net
