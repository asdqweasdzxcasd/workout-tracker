# =====================================================
# 로컬 개발용 환경변수 샘플
# 사용법: cp .env.local.example .env.local
# .env.local 은 .gitignore 로 추적 제외 (실제 비밀번호는 코드에 두지 않는다)
# =====================================================

# --- Postgres (docker-compose.local.yml가 참조) ---
POSTGRES_DB=workout_tracker
POSTGRES_USER=workout
POSTGRES_PASSWORD=workout_pw_local

# --- Backend (Spring Boot, application-local.yml가 참조) ---
DB_URL=jdbc:postgresql://localhost:5432/workout_tracker
DB_USERNAME=workout
DB_PASSWORD=workout_pw_local

# Day 2 이후에 사용될 값 (지금은 자리만 잡음)
# JWT_SECRET=replace-with-32-chars-or-more-secret-please
# JWT_EXPIRES_IN=3600
