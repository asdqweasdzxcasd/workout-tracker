        <mxCell id="sg-alb-desc" value="Inbound:&#xa;TCP 80 ← 0.0.0.0/0 (Internet)&#xa;&#xa;Outbound:&#xa;All ← (default)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;spacingLeft=10" vertex="1" parent="sg-alb">
