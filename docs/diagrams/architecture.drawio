        </mxCell>

        <mxCell id="sg-chain" value="Source SG 체인:&#xa;Internet → alb-sg → web-sg → db-sg&#xa;(각 계층이 바로 위 SG 만 허용 → CIDR 0.0.0.0/0 사용 최소화)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;fontStyle=1;fillColor=#f5f5f5;strokeColor=#666666" vertex="1" parent="sg-box">
