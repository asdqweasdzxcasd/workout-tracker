        </mxCell>
        <mxCell id="sg-web-desc" value="Inbound:&#xa;TCP 8080 ← alb-sg (Source SG ⭐)&#xa;TCP 8081 ← alb-sg&#xa;TCP 22  ← <내 IP>/32 (SSH)&#xa;Outbound: All" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;spacingLeft=10" vertex="1" parent="sg-web">
