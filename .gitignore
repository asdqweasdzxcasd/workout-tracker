pnpm-debug.log*

# =====================================================
# Java / Gradle / Spring Boot
# =====================================================
# Gradle 빌드 결과물
backend/build/
backend/.gradle/
backend/out/
backend/bin/

# Gradle wrapper의 jar는 추적 (체크인 표준)
# !backend/gradle/wrapper/gradle-wrapper.jar

# Java 컴파일 결과
*.class

# Spring Boot 패키지 결과물
*.jar
*.war
*.ear

# 단, Gradle wrapper jar 는 예외로 포함
!gradle-wrapper.jar

